{
  "profiles": {
    "IIS Express (Rider)": {
      "commandName": "Executable",
      "executablePath": "$(MSBuildExtensionsPath64)/../IIS Express/iisexpress.exe",
      "commandLineArgs": "/path:\"$(MSBuildProjectDirectory)\" /port:1543",
      "workingDirectory": "$(MSBuildExtensionsPath64)/../IIS Express",
      "environmentVariables": {
        "WEBSITE_PATH": "$(ProjectDir)",
        "ASPNETCORE_ENVIRONMENT": "$(Configuration)"
      },
      "launchBrowser": true,
      "launchUrl": "http://localhost:1543/",
      "applicationUrl": "http://localhost:1543"
    }
  }
}