@model ProductCatalog.Web.ViewModels.ProductEditViewModel

@{
    ViewBag.Title = "Chỉnh sửa sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2>
                <i class="fa fa-edit"></i> Chỉnh sửa sản phẩm
            </h2>
            <hr />

            @using (Html.BeginForm("Edit", "Product", FormMethod.Post, new { @class = "form-horizontal" }))
            {
                @Html.AntiForgeryToken()

                <div class="form-group row">
                    <label class="col-md-3 col-form-label">
                        <strong>ID sản phẩm:</strong>
                    </label>
                    <div class="col-md-9">
                        @Html.DisplayFor(m => m.Id)
                        @Html.HiddenFor(m => m.Id)
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-md-3 col-form-label">
                        <strong>Tên sản phẩm:</strong>
                    </label>
                    <div class="col-md-9">
                        @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-md-3 col-form-label">
                        <strong>Mô tả:</strong>
                    </label>
                    <div class="col-md-9">
                        @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = 4 })
                        @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-md-3 col-form-label">
                        <strong>Giá (₫):</strong>
                    </label>
                    <div class="col-md-9">
                        @Html.TextBoxFor(m => m.Price, new { @class = "form-control", type = "number", step = "0.01" })
                        @Html.ValidationMessageFor(m => m.Price, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-md-3 col-form-label">
                        <strong>Tồn kho:</strong>
                    </label>
                    <div class="col-md-9">
                        @Html.TextBoxFor(m => m.Stock, new { @class = "form-control", type = "number" })
                        @Html.ValidationMessageFor(m => m.Stock, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-md-3 col-form-label">
                        <strong>Danh mục:</strong>
                    </label>
                    <div class="col-md-9">
                        @Html.DropDownListFor(m => m.CategoryId,
                            new SelectList(Model.Categories, "Id", "Name"),
                            "-- Chọn danh mục --",
                            new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.CategoryId, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-md-3 col-form-label">
                        <strong>Trạng thái:</strong>
                    </label>
                    <div class="col-md-9">
                        <div class="form-check">
                            @Html.CheckBoxFor(m => m.IsActive, new { @class = "form-check-input" })
                            <label class="form-check-label" for="IsActive">
                                Hoạt động
                            </label>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="form-group row">
                    <div class="col-md-9 offset-md-3">
                        <button type="submit" class="btn btn-success">
                            <i class="fa fa-save"></i> Cập nhật sản phẩm
                        </button>
                        <a href="@Url.Action("Index", "Product")" class="btn btn-secondary">
                            <i class="fa fa-times"></i> Hủy
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script type="text/javascript">
        $(document).ready(function () {
            // Format currency display
            $('input[name="Price"]').on('blur', function () {
                var value = $(this).val();
                if (value) {
                    var formatted = parseFloat(value).toLocaleString('vi-VN');
                    console.log('Price: ' + formatted);
                }
            });
        });
    </script>
}
