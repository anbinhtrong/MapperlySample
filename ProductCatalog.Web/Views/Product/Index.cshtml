
@using ProductCatalog.Web.Extensions
@model IEnumerable<ProductCatalog.Web.ViewModels.ProductViewModel>

@{
    ViewBag.Title = "Danh sách sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>
                <i class="fa fa-list"></i> Danh sách sản phẩm
            </h2>
        </div>
        <div class="col-md-4 text-right">
            <a href="@Url.Action("Create", "Product")" class="btn btn-primary">
                <i class="fa fa-plus"></i> Thêm sản phẩm mới
            </a>
        </div>
    </div>

    @if (Model.Count() > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 5%;">#</th>
                        <th style="width: 20%;">Tên sản phẩm</th>
                        <th style="width: 15%;">Danh mục</th>
                        <th style="width: 12%;">Giá</th>
                        <th style="width: 10%;">Tồn kho</th>
                        <th style="width: 10%;">Ngày tạo</th>
                        <th style="width: 10%;">Trạng thái</th>
                        <th style="width: 18%;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int index = 1;
                        foreach (var product in Model)
                        {
                            <tr>
                                <td>@index</td>
                                <td>
                                    <strong>@product.Name</strong>
                                    @if (!string.IsNullOrEmpty(product.Description))
                                    {
                                        <br />
                                        <small class="text-muted">@Html.Truncate(product.Description, 50)</small>
                                    }
                                </td>
                                <td>
                                    <span class="badge badge-info">@product.CategoryName</span>
                                </td>
                                <td>
                                    <span class="text-success font-weight-bold">@product.PriceDisplay</span>
                                </td>
                                <td>
                                    @if (product.StockStatus == "Còn hàng")
                                    {
                                        <span class="badge badge-success">@product.StockStatus</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">@product.StockStatus</span>
                                    }
                                </td>
                                <td>@product.CreatedAtDisplay</td>
                                <td>
                                    @if (product.IsActive)
                                    {
                                        <span class="badge badge-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary">Không hoạt động</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("Detail", "Product", new { id = product.Id })" 
                                       class="btn btn-sm btn-info" title="Xem chi tiết">
                                        <i class="fa fa-eye"></i> Xem
                                    </a>
                                    <a href="@Url.Action("Edit", "Product", new { id = product.Id })" 
                                       class="btn btn-sm btn-warning" title="Chỉnh sửa">
                                        <i class="fa fa-edit"></i> Sửa
                                    </a>
                                    <a href="@Url.Action("Delete", "Product", new { id = product.Id })" 
                                       class="btn btn-sm btn-danger" 
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa?')" 
                                       title="Xóa">
                                        <i class="fa fa-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                            index++;
                        }
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="fa fa-info-circle"></i> Không có sản phẩm nào. 
            <a href="@Url.Action("Create", "Product")" class="alert-link">Thêm sản phẩm mới</a>
        </div>
    }
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f5f5f5;
    }

    .btn-sm {
        padding: 0.25rem 0.5rem;
        font-size: 0.875rem;
        margin: 0 2px;
    }

    .badge {
        padding: 0.35rem 0.65rem;
    }
</style>
